# Copy this file to web/.env.local and fill in real values.
# .env.local is git-ignored — never commit real secrets.
#
# This example is at the project root for visibility, but the real .env.local
# lives inside web/ since that's where Next.js looks for it.

# === Supabase ===
# Get these from Supabase project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# === Azure OpenAI (Wave 3) ===
AZURE_OPENAI_ENDPOINT=https://your-openai-resource.openai.azure.com/
AZURE_OPENAI_API_KEY=your-key-here
AZURE_OPENAI_DEPLOYMENT_NAME=gpt-4o-mini

# === Azure Document Intelligence (Wave 3) ===
AZURE_DOCUMENT_INTELLIGENCE_ENDPOINT=https://your-doc-intel.cognitiveservices.azure.com/
AZURE_DOCUMENT_INTELLIGENCE_KEY=your-key-here

# === App config ===
NEXT_PUBLIC_APP_NAME=ReEarth Demo
NEXT_PUBLIC_APP_ENV=development
